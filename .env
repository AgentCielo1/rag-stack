# Qdrant Configuration
QDRANT_API_KEY=

# Chroma Configuration
CHROMA_SERVER_HOST=0.0.0.0
CHROMA_SERVER_PORT=8000

# SearXNG Configuration
SEARXNG_BASE_URL=http://localhost:8888/
SEARXNG_INSTANCE_NAME=Local RAG Search
SEARXNG_SECRET_KEY=change-this-secret-key-32-chars

# Proxy Configuration (uncomment and set if needed)
# PROXY_HTTP=http://proxy.example.com:8080
# PROXY_HTTPS=http://proxy.example.com:8080
# PROXY_SOCKS5=socks5://proxy.example.com:1080

# Open WebUI Configuration
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Compose Settings
COMPOSE_PROJECT_NAME=rag-stack
